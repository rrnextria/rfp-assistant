# Maistro Orchestrator Configuration
# Copy to .env and customize. CLI flags override these values.
# Precedence: CLI flag > .env > hardcoded default

# Codex reviewer model (default: gpt-5.4)
MAISTRO_CODEX_MODEL=gpt-5.4

# Codex reasoning effort (default: high)
# Valid values: low, medium, high
MAISTRO_CODEX_REASONING=high

# Claude model for research mode (default: opus)
MAISTRO_CLAUDE_MODEL=opus

# Reviewer wall-clock timeout in seconds (default: 1800)
MAISTRO_TIMEOUT=1800

# Kill reviewer after N seconds of no output (default: 600)
MAISTRO_IDLE_TIMEOUT=600
